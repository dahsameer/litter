{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Litter past release metadata list",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "version",
      "versionCode",
      "publishedAt",
      "downloadUrl",
      "releaseNotes",
      "apkSize",
      "sha256",
      "prerelease",
      "draft"
    ],
    "properties": {
      "version": { "type": "string" },
      "versionCode": { "type": "integer" },
      "publishedAt": { "type": "string" },
      "downloadUrl": { "type": "string" },
      "releaseNotes": { "type": "string" },
      "apkSize": { "type": "integer" },
      "sha256": { "type": "string" },
      "prerelease": { "type": "boolean" },
      "draft": { "type": "boolean" }
    },
    "additionalProperties": false
  }
}
